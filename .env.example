# ============================================================
# QC Tool — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ------------------------------------------------------------
# Anthropic / Claude
# ------------------------------------------------------------
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model to use. claude-sonnet-4-6 is the default.
# Switch to claude-opus-4-6 for complex multi-table queries.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ------------------------------------------------------------
# SQL Server
# ------------------------------------------------------------
# Hostname or IP of the SQL Server instance.
# Azure SQL example:  myserver.database.windows.net
# On-prem example:    MYSERVER\INSTANCENAME
DB_SERVER=

# Target database name
DB_NAME=

# Read-only SQL login (see BACKEND-PLAN.md for the DBA script)
DB_USER=qc_readonly
DB_PASSWORD=

# Set to true for Azure SQL or any server using TLS.
# Set to false for local dev without TLS (not for production).
DB_ENCRYPT=true

# Set to true only when connecting to a local dev instance
# with a self-signed certificate. Never true in production.
DB_TRUST_SERVER_CERT=false

# ------------------------------------------------------------
# Query limits
# ------------------------------------------------------------
# Maximum rows returned per query (prevents runaway result sets)
MAX_ROWS=1000

# Maximum milliseconds a query may run before it is cancelled
QUERY_TIMEOUT_MS=30000

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
PORT=3001
NODE_ENV=development

# ------------------------------------------------------------
# Auth — choose ONE option and leave the other blank
# ------------------------------------------------------------

# Option A: Simple JWT (good for internal / standalone deployments)
# Generate a strong random secret, e.g.: openssl rand -hex 64
JWT_SECRET=

# Option B: Azure Active Directory
# Register an app in Azure AD and paste the values here
AZURE_CLIENT_ID=
AZURE_TENANT_ID=

# ------------------------------------------------------------
# Rate limiting
# ------------------------------------------------------------
# Max requests per user per minute
RATE_LIMIT_PER_MINUTE=20
